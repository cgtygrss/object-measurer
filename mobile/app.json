{
  "expo": {
    "name": "Object Measurer",
    "slug": "object-measurer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "object-measurer",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.objectmeasurer.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Object Measurer needs camera access to photograph objects for measurement.",
        "NSPhotoLibraryUsageDescription": "Object Measurer needs photo library access to import images for measurement."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.objectmeasurer.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Object Measurer needs camera access to photograph objects for measurement."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Object Measurer needs photo library access to import images for measurement."
        }
      ]
    ]
  }
}
