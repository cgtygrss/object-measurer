# ─── App Settings ──────────────────────────────────
APP_NAME=Object Measurer API
APP_VERSION=1.0.0
DEBUG=true

# ─── Database ──────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/object_measurer

# ─── JWT Auth ──────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=10080

# ─── File Storage ──────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ─── S3 (optional — for production) ────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION=eu-central-1
